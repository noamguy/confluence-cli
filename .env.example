# Anthropic API key for Claude Sonnet (claude-sonnet-4-6)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Atlassian OAuth 2.0 client credentials.
# Create an OAuth 2.0 (3LO) integration at https://developer.atlassian.com/console/myapps/
# Redirect URI should be: http://localhost:8765/callback
ATLASSIAN_CLIENT_ID=your-client-id
ATLASSIAN_CLIENT_SECRET=your-client-secret

# Confluence workspace
CONFLUENCE_BASE_URL=https://your-workspace.atlassian.net
CONFLUENCE_SPACE_KEY=PH

# Optional: override token cache location
# CONFLUENCE_CLI_TOKEN_PATH=~/.confluence-cli/token.json
